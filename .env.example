# Copie para ".env" e preencha. O ".env" é ignorado pelo git e NUNCA é versionado.

# Aplicação
APP_NAME="CEMA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en

# Fila — usar conexão database em runtime; testes usam sync (phpunit.xml)
QUEUE_CONNECTION=database

# Banco de dados (MySQL no Docker — ver docker-compose.yml)
# DB_HOST = nome do serviço MySQL na rede do Docker (a app roda em container).
# Para acessar do host (Adminer/cliente externo) use 127.0.0.1:3306.
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=cema
DB_USERNAME=cema
DB_PASSWORD=secret
DB_ROOT_PASSWORD=secret

# E-mail local (Mailpit — UI em http://localhost:8025)
# MAIL_HOST = nome do serviço Mailpit na rede do Docker.
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null

# Fonte de migração — REST do site ATUAL (SOMENTE LEITURA / GET)
# WP_USER é o E-MAIL do usuário de serviço (@cemanet.org.br); login curto dá 401.
CEMA_WP_BASE_URL=https://cemanet.org.br
CEMA_WP_USER=
CEMA_WP_APP_PASSWORD=

# Banco LEGADO (WordPress atual) — SOMENTE LEITURA, ao vivo via túnel SSH.
# Dados sempre atualizados. Use um usuário MySQL só-SELECT (NUNCA o root).
# Suba o túnel antes de conectar (passo a passo em DB-LEGADO.md):
#   ssh -N -L 3307:127.0.0.1:3306 deploy@SEU_VPS
# A app roda em container: use host.docker.internal para alcançar o túnel no host
# (com 127.0.0.1 o container apontaria para si mesmo, não para a sua máquina).
LEGADO_DB_HOST=host.docker.internal
LEGADO_DB_PORT=3307
LEGADO_DB_DATABASE=wordpress_cemanet
LEGADO_DB_USERNAME=
LEGADO_DB_PASSWORD=
